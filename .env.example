# ============================================================================
# LLM Provider Configuration
# ============================================================================
# BASE_URL and API_KEY are the standard configurations for model call authentication.
# These variables support OpenAI, Gemini, LM Studio, Ollama, and other providers.

BASE_URL=https://api.openai.com/v1
API_KEY=sk-your-openai-api-key-here

# Example BASE_URL values:
# - OpenAI:    https://api.openai.com/v1
# - Gemini:    https://generativelanguage.googleapis.com
# - LM Studio: http://localhost:1234/v1
# - Ollama:    http://localhost:11434/v1

# ============================================================================
# Anthropic Claude Configuration
# ============================================================================
# Use provider: claude in your workflow YAML to use Claude models.
# Supported models: claude-opus-4-5, claude-sonnet-4-5, claude-haiku-3-5
# Get your API key from: https://console.anthropic.com

ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ============================================================================
# Optional: Web Search and Reading Tools
# ============================================================================

# SERPER_DEV_API_KEY=your-serper-api-key-here
# Get from: https://serper.dev

# JINA_API_KEY=your-jina-api-key-here
# Get from: https://jina.ai

# ============================================================================
# Performance Tuning
# ============================================================================

# DEVALL_LLM_CACHE=true         # Enable/disable LLM response cache (default: true)
# LLM_CACHE_MAX_ENTRIES=512     # Max in-memory cache entries (default: 512)
# DEVALL_MAX_PARALLEL_TOOLS=8   # Max concurrent tool calls per agent node (default: 8)

# ============================================================================
# CRM Integration (HubSpot)
# ============================================================================
# Used by crm_* tool functions and /api/crm/* REST endpoints.
# Get a Private App token from: https://app.hubspot.com/private-apps

# HUBSPOT_API_KEY=pat-na1-your-private-app-token-here

# ============================================================================
# Cloud Deployment — AWS S3
# ============================================================================
# Used by deploy_to_s3 tool function and /api/deploy/s3 REST endpoint.

# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_REGION=us-east-1

# ============================================================================
# Cloud Deployment — Google Cloud Storage
# ============================================================================
# Used by deploy_to_gcs tool function and /api/deploy/gcs REST endpoint.
# Point to a service-account JSON key file downloaded from Google Cloud Console.

# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CLOUD_PROJECT=my-gcp-project-id

# ============================================================================
# Cloud Deployment — GitHub Releases
# ============================================================================
# Used by deploy_to_github_release tool and /api/deploy/github-release endpoint.
# Create a fine-grained token with Contents: write at https://github.com/settings/tokens

# GITHUB_TOKEN=github_pat_your_token_here