modules = ["python-3.12", "vue-node-20", "nodejs-20", "web", "python3", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["SDL2", "SDL2_image", "SDL2_mixer", "SDL2_ttf", "cairo", "cargo", "ffmpeg-full", "fontconfig", "freetype", "geos", "ghostscript", "glibcLocales", "gobject-introspection", "gtk3", "libiconv", "libjpeg", "libpng", "libxcrypt", "libyaml", "pkg-config", "portmidi", "proj", "qhull", "rustc", "tcl", "tk"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python server_main.py --host 0.0.0.0 --port 8000"
waitForPort = 8000

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8000
externalPort = 80

[userenv]

[userenv.shared]
JWT_SECRET = "a2342e489e3ccbd3ae286a70dc9b1d3034353d2a03c2660c6dcf67bef91b16c0"

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--workers=2", "--timeout=120", "server.app:app", "-k", "uvicorn.workers.UvicornWorker"]
build = ["bash", "-c", "cd frontend && npm run build"]
